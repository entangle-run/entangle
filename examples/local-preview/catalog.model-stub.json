{
  "schemaVersion": "1",
  "catalogId": "local-preview-catalog",
  "relays": [
    {
      "id": "local-relay",
      "displayName": "Local Relay",
      "readUrls": [
        "ws://strfry:7777"
      ],
      "writeUrls": [
        "ws://strfry:7777"
      ],
      "authMode": "none"
    }
  ],
  "gitServices": [
    {
      "id": "local-gitea",
      "displayName": "Local Preview Gitea",
      "baseUrl": "http://gitea:3000",
      "remoteBase": "http://gitea:3000",
      "transportKind": "https",
      "authMode": "https_token",
      "defaultNamespace": "local-preview",
      "provisioning": {
        "mode": "gitea_api",
        "apiBaseUrl": "http://gitea:3000/api/v1",
        "secretRef": "secret://git-services/local-preview/provisioning"
      }
    }
  ],
  "modelEndpoints": [
    {
      "id": "local-preview-model",
      "displayName": "Local Preview Model Stub",
      "adapterKind": "openai_compatible",
      "baseUrl": "http://entangle-local-preview-model:8080/v1",
      "authMode": "api_key_bearer",
      "secretRef": "secret://local/local-preview-model",
      "defaultModel": "local-preview-model"
    }
  ],
  "defaults": {
    "relayProfileRefs": [
      "local-relay"
    ],
    "gitServiceRef": "local-gitea",
    "modelEndpointRef": "local-preview-model"
  }
}
