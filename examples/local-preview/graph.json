{
  "schemaVersion": "1",
  "graphId": "local-preview-graph",
  "name": "Local Preview Graph",
  "nodes": [
    {
      "nodeId": "local-preview-user",
      "displayName": "Local Preview User",
      "nodeKind": "user"
    },
    {
      "nodeId": "local-preview-planner",
      "displayName": "Local Preview Planner",
      "nodeKind": "worker",
      "packageSourceRef": "local-preview-package-source",
      "resourceBindings": {
        "relayProfileRefs": [
          "local-relay"
        ],
        "primaryRelayProfileRef": "local-relay",
        "gitServiceRefs": [
          "local-gitea"
        ],
        "primaryGitServiceRef": "local-gitea",
        "modelEndpointProfileRef": "local-preview-model",
        "externalPrincipalRefs": [
          "local-preview-git"
        ]
      }
    },
    {
      "nodeId": "local-preview-builder",
      "displayName": "Local Preview Builder",
      "nodeKind": "worker",
      "packageSourceRef": "local-preview-package-source",
      "resourceBindings": {
        "relayProfileRefs": [
          "local-relay"
        ],
        "primaryRelayProfileRef": "local-relay",
        "gitServiceRefs": [
          "local-gitea"
        ],
        "primaryGitServiceRef": "local-gitea",
        "modelEndpointProfileRef": "local-preview-model",
        "externalPrincipalRefs": [
          "local-preview-git"
        ]
      }
    }
  ],
  "edges": [
    {
      "edgeId": "local-preview-user-to-planner",
      "fromNodeId": "local-preview-user",
      "toNodeId": "local-preview-planner",
      "relation": "delegates_to",
      "enabled": true,
      "transportPolicy": {
        "mode": "bidirectional_shared_set",
        "relayProfileRefs": [
          "local-relay"
        ],
        "channel": "local-preview"
      }
    },
    {
      "edgeId": "local-preview-user-to-builder",
      "fromNodeId": "local-preview-user",
      "toNodeId": "local-preview-builder",
      "relation": "delegates_to",
      "enabled": true,
      "transportPolicy": {
        "mode": "bidirectional_shared_set",
        "relayProfileRefs": [
          "local-relay"
        ],
        "channel": "local-preview-handoff"
      }
    },
    {
      "edgeId": "local-preview-planner-to-builder",
      "fromNodeId": "local-preview-planner",
      "toNodeId": "local-preview-builder",
      "relation": "routes_to",
      "enabled": true,
      "transportPolicy": {
        "mode": "bidirectional_shared_set",
        "relayProfileRefs": [
          "local-relay"
        ],
        "channel": "local-preview-artifact-handoff"
      }
    },
    {
      "edgeId": "local-preview-builder-review",
      "fromNodeId": "local-preview-builder",
      "toNodeId": "local-preview-planner",
      "relation": "reviews",
      "enabled": true,
      "transportPolicy": {
        "mode": "bidirectional_shared_set",
        "relayProfileRefs": [
          "local-relay"
        ],
        "channel": "local-preview-review"
      }
    }
  ],
  "defaults": {
    "resourceBindings": {
      "relayProfileRefs": [
        "local-relay"
      ],
      "primaryRelayProfileRef": "local-relay",
      "gitServiceRefs": [
        "local-gitea"
      ],
      "primaryGitServiceRef": "local-gitea",
      "modelEndpointProfileRef": "local-preview-model",
      "externalPrincipalRefs": [
        "local-preview-git"
      ]
    },
    "runtimeProfile": "hackathon_local"
  }
}
