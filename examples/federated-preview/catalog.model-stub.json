{
  "schemaVersion": "1",
  "catalogId": "federated-preview-catalog",
  "relays": [
    {
      "id": "preview-relay",
      "displayName": "Preview Relay",
      "readUrls": [
        "ws://strfry:7777"
      ],
      "writeUrls": [
        "ws://strfry:7777"
      ],
      "authMode": "none"
    }
  ],
  "gitServices": [
    {
      "id": "gitea",
      "displayName": "Federated Preview Gitea",
      "baseUrl": "http://gitea:3000",
      "remoteBase": "http://gitea:3000",
      "transportKind": "https",
      "authMode": "https_token",
      "defaultNamespace": "federated-preview",
      "provisioning": {
        "mode": "gitea_api",
        "apiBaseUrl": "http://gitea:3000/api/v1",
        "secretRef": "secret://git-services/federated-preview/provisioning"
      }
    }
  ],
  "modelEndpoints": [
    {
      "id": "federated-preview-model",
      "displayName": "Federated Preview Model Stub",
      "adapterKind": "openai_compatible",
      "baseUrl": "http://entangle-preview-model:8080/v1",
      "authMode": "api_key_bearer",
      "secretRef": "secret://local/federated-preview-model",
      "defaultModel": "federated-preview-model"
    }
  ],
  "defaults": {
    "relayProfileRefs": [
      "preview-relay"
    ],
    "gitServiceRef": "gitea",
    "modelEndpointRef": "federated-preview-model"
  }
}
