{
  "name": "@entangle/host",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "pnpm run typecheck",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src scripts --max-warnings 0",
    "start": "node dist/index.js",
    "test": "vitest run --config ../../vitest.config.ts --environment node src/*.test.ts --pool=forks --maxWorkers=1 --testTimeout=30000",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@entangle/nostr-fabric": "workspace:*",
    "@entangle/types": "workspace:*",
    "@entangle/validator": "workspace:*",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.5",
    "nostr-tools": "^2.23.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
