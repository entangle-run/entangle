{
  "name": "@entangle/host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "pnpm run typecheck",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings 0",
    "start": "node dist/index.js",
    "test": "vitest run --environment node src/*.test.ts",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@entangle/types": "workspace:*",
    "@entangle/validator": "workspace:*",
    "fastify": "^5.8.5",
    "nostr-tools": "^2.23.3",
    "zod": "^4.3.6"
  }
}
