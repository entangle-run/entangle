{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "@entangle/host-client": [
        "../../packages/host-client/src/index.ts"
      ],
      "@entangle/types": [
        "../../packages/types/src/index.ts"
      ]
    },
    "types": [
      "vite/client"
    ],
    "noEmit": true
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
