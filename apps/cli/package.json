{
  "name": "@entangle/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "entangle": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "pnpm run typecheck",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config ../../vitest.config.ts --environment node --pool=forks --maxWorkers=1 src/*.test.ts",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@entangle/host-client": "workspace:*",
    "@entangle/package-scaffold": "workspace:*",
    "@entangle/types": "workspace:*",
    "@entangle/validator": "workspace:*",
    "commander": "^14.0.3",
    "nostr-tools": "^2.23.3"
  }
}
