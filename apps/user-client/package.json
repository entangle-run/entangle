{
  "name": "@entangle/user-client",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "check": "pnpm run typecheck",
    "clean": "rm -rf dist",
    "dev": "vite",
    "lint": "eslint src vite.config.ts --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run --config ../../vitest.config.ts --environment node --pool=forks --maxWorkers=1 src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@entangle/types": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.9"
  }
}
