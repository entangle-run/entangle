{
  "name": "entangle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm typecheck",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "eslint apps services packages --fix",
    "ops:check-federated-dev": "node scripts/check-federated-dev-profile.mjs",
    "ops:check-federated-dev:strict": "node scripts/check-federated-dev-profile.mjs --strict",
    "ops:check-product-naming": "node scripts/check-active-product-naming.mjs",
    "ops:smoke-federated-dev": "node scripts/smoke-federated-dev-profile.mjs",
    "ops:smoke-federated-dev:diagnostics": "node scripts/smoke-federated-dev-diagnostics.mjs",
    "ops:smoke-federated-dev:reliability": "node scripts/smoke-federated-dev-reliability.mjs",
    "ops:smoke-federated-dev:disposable": "node scripts/smoke-federated-dev-profile-disposable.mjs",
    "ops:smoke-federated-dev:disposable:runtime": "node scripts/smoke-federated-dev-profile-disposable.mjs --include-runtime",
    "ops:smoke-federated-control": "node scripts/smoke-federated-control-plane.mjs",
    "ops:smoke-federated-live-relay": "node scripts/smoke-federated-live-relay.mjs",
    "ops:smoke-federated-process-runner": "node scripts/smoke-federated-process-runner.mjs",
    "ops:smoke-federated-process-runner:fake-opencode": "node scripts/smoke-federated-process-runner.mjs --relay-url ws://localhost:7777 --timeout-ms 60000 --use-fake-opencode-server",
    "ops:smoke-federated-dev:runtime": "node scripts/smoke-federated-dev-runtime.mjs",
    "ops:demo-federated-preview": "node scripts/federated-preview-demo.mjs",
    "ops:demo-federated-preview:reset": "node scripts/federated-preview-demo.mjs --reset",
    "ops:demo-user-node-runtime": "node scripts/federated-user-node-runtime-demo.mjs",
    "ops:demo-user-node-runtime:fake-opencode": "node scripts/federated-user-node-runtime-demo.mjs --fake-opencode-server",
    "ops:distributed-proof-kit": "node scripts/federated-distributed-proof-kit.mjs",
    "ops:distributed-proof-verify": "node scripts/federated-distributed-proof-verify.mjs",
    "ops:smoke-distributed-proof-tools": "node scripts/smoke-distributed-proof-tools.mjs",
    "ops:fake-openai-provider": "node scripts/fake-openai-compatible-provider.mjs",
    "ops:smoke-fake-openai-provider": "node scripts/smoke-fake-openai-compatible-provider.mjs",
    "ops:fake-opencode-server": "node scripts/fake-opencode-server.mjs",
    "ops:smoke-fake-opencode-server": "node scripts/smoke-fake-opencode-server.mjs",
    "test": "vitest run --config vitest.aggregate.config.ts --environment node --pool=forks --maxWorkers=1 --exclude 'services/host/src/**/*.test.ts' --exclude 'services/runner/src/**/*.test.ts' && pnpm --filter @entangle/runner test && pnpm --filter @entangle/host test",
    "test:coverage": "vitest run --config vitest.aggregate.config.ts --environment node --pool=forks --maxWorkers=1 --exclude 'services/host/src/**/*.test.ts' --exclude 'services/runner/src/**/*.test.ts' --coverage.enabled true && pnpm --filter @entangle/runner test -- --coverage.enabled true && pnpm --filter @entangle/host test -- --coverage.enabled true",
    "typecheck": "tsc -b tsconfig.solution.json --pretty false && pnpm --filter @entangle/studio typecheck && pnpm --filter @entangle/user-client typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
