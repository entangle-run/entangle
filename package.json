{
  "name": "entangle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm typecheck",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "eslint apps services packages --fix",
    "ops:check-local": "node scripts/check-local-profile.mjs",
    "ops:check-local:strict": "node scripts/check-local-profile.mjs --strict",
    "ops:smoke-local": "node scripts/smoke-local-profile.mjs",
    "ops:smoke-local:diagnostics": "node scripts/smoke-local-diagnostics.mjs",
    "ops:smoke-local:reliability": "node scripts/smoke-local-reliability.mjs",
    "ops:smoke-local:disposable": "node scripts/smoke-local-profile-disposable.mjs",
    "ops:smoke-local:disposable:runtime": "node scripts/smoke-local-profile-disposable.mjs --include-runtime",
    "ops:smoke-local:runtime": "node scripts/smoke-local-runtime.mjs",
    "ops:demo-federated-preview": "node scripts/federated-preview-demo.mjs",
    "ops:demo-federated-preview:reset": "node scripts/federated-preview-demo.mjs --reset",
    "test": "turbo run test --concurrency=1",
    "test:coverage": "vitest run --config vitest.config.ts packages/**/*.test.ts services/**/*.test.ts --coverage.enabled true",
    "typecheck": "tsc -b tsconfig.solution.json --pretty false && pnpm --filter @entangle/studio typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
