{
  "name": "@entangle/validator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "pnpm run typecheck",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config ../../vitest.config.ts --environment node src/index.test.ts --pool=forks",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@entangle/types": "workspace:*"
  }
}
